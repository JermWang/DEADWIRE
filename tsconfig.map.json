{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "rootDir": "game/src/map",
    "outDir": "game/src/map/runtime",
    "strict": true,
    "skipLibCheck": true,
    "declaration": false,
    "sourceMap": true,
    "noEmitOnError": true
  },
  "include": ["game/src/map/**/*.ts"],
  "exclude": ["game/src/map/runtime"]
}
