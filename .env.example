# Deadwire — env template. Copy to .env and fill. Safe to commit (no secrets).
# Public/client config lives in game/src/config/runtime.js.

# ── Match server (server/match-server.mjs) ──────────────────────────────────
PORT=5181
MATCH_PORT=5181
HOST=127.0.0.1
MATCH_SERVER_URL=

# ── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_PROJECT_REF=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=

# ── Solana · MAINNET ────────────────────────────────────────────────────────
SOLANA_NETWORK=mainnet-beta
SOLANA_RPC_URL=
HELIUS_API_KEY=

# ── $DEAD token + Gold economy ──────────────────────────────────────────────
DEAD_MINT=
DEAD_TOKEN_SYMBOL=DEAD
DEAD_TOKEN_DECIMALS=6
TREASURY_WALLET_ADDRESS=
GOLD_PER_DEAD=1000

# ── Admin ───────────────────────────────────────────────────────────────────
ADMIN_EMAILS=
ADMIN_WALLETS=

# ── Optional / future ───────────────────────────────────────────────────────
HOT_WALLET_PRIVATE_KEY=
